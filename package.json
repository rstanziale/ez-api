{
  "name": "@rs-box/ez-api",
  "version": "1.0.0",
  "description": "API development toolkit powered by TypeSpec",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/rstanziale/ez-api.git"
  },
  "keywords": [
    "typespec",
    "api",
    "typescript"
  ],
  "scripts": {
    "prepare": "husky",
    "format": "tsp format \"**/*.tsp\"",
    "test": "vitest",
    "api:new": "node --import=tsx tools/api-new.ts",
    "api:import": "node --import=tsx tools/api-import.ts",
    "build:all": "npm-run-all --parallel compile:i18n-resources",
    "compile:i18n-resources": "node --import=tsx tools/build.ts i18n-resources",
    "watch:i18n-resources": "tsp compile projects/i18n-resources/main.tsp --watch --emit @typespec/openapi3"
  },
  "author": "Roberto B. Stanziale",
  "license": "MIT",
  "dependencies": {
    "@typespec/compiler": "latest",
    "@typespec/http": "latest",
    "@typespec/openapi": "latest",
    "@typespec/openapi3": "latest",
    "@typespec/rest": "latest",
    "@typespec/versioning": "latest"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.6.0",
    "@typespec/prettier-plugin-typespec": "^1.11.0",
    "@vitest/coverage-v8": "^4.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "memfs": "^4.57.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "private": true
}
