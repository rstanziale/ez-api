{
  "tabWidth": 2,
  "useTabs": false,
  "singleQuote": true,
  "semi": true,
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "trailingComma": "es5",
  "bracketSameLine": true,
  "printWidth": 100,
  "endOfLine": "auto",
  "importOrder": ["^node:(.*)$", "^[a-zA-Z]", "^[./]"],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "plugins": ["@typespec/prettier-plugin-typespec", "@trivago/prettier-plugin-sort-imports"],
  "overrides": [{ "files": "*.tsp", "options": { "parser": "typespec" } }]
}
